{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@api/*": ["api/*"],
      "@public/*": ["public/*"],
      "@components/*": ["components/*"],
      "@pages/*": ["pages/*"],
      "@routing/*": ["routing/*"],
      "@store/*": ["store/*"],
      "@hooks/*": ["hooks/*"],
      "@enums/*": ["enums/*"],
      "@i18n": ["i18n/index.ts"],
      "@i18n/*": ["i18n/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@schemas/*": ["schemas/*"],
      "@interfaces/*": ["interfaces/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "types/**/*.d.ts",
    "tailwind.config.mjs",
    "./src/**/*"
  ],
  "exclude": ["node_modules"]
}
